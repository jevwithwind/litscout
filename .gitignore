# =============================================================================
# litscout — .gitignore
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg
.eggs/

# Virtual environment
.venv/
venv/
env/

# Environment variables (NEVER commit)
.env

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# litscout runtime
temp/
output/kept_papers/
output/reports/
output/manifest.json

# Keep output directory structure
!output/.gitkeep
!output/kept_papers/.gitkeep
!output/reports/.gitkeep

# PDF files (don't commit papers)
*.pdf

# Logs
*.log

# User input (don't commit personal research angle or API settings)
input/research.md
input/settings.yaml

# Keep the template and example
!input/research.example.md
!input/settings.example.yaml
