# =============================================================================
# litscout — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# All API keys and sensitive credentials go here, NOT in config.yaml.

# -----------------------------------------------------------------------------
# LLM Configuration (for paper screening, query generation, sufficiency checks)
# Any OpenAI-compatible endpoint works (DashScope, OpenAI, Azure, Ollama, etc.)
# -----------------------------------------------------------------------------
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_dashscope_api_key_here
LLM_MODEL=qwen3.6-plus

# -----------------------------------------------------------------------------
# Semantic Scholar API (free, optional but recommended for higher rate limits)
# Request a key at: https://www.semanticscholar.org/product/api#api-key
# Without a key: shared rate limit across all unauthenticated users
# With a key: 1 request/second guaranteed
# -----------------------------------------------------------------------------
S2_API_KEY=your_semantic_scholar_api_key_here

# -----------------------------------------------------------------------------
# OpenAlex API (free, no key required)
# Providing an email is polite and gets you into the "polite pool" (faster)
# See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
# -----------------------------------------------------------------------------
OPENALEX_EMAIL=your_email@example.com

# -----------------------------------------------------------------------------
# Elsevier / ScienceDirect API (optional — for paywalled paper access)
# Get your API key at: https://dev.elsevier.com/
# Institutional token: email datasupport@elsevier.com from your university email
# If on campus/VPN, API key alone may be sufficient (leave INST_TOKEN blank)
# -----------------------------------------------------------------------------
ELSEVIER_API_KEY=
ELSEVIER_INST_TOKEN=
