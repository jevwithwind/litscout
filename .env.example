# =============================================================================
# litscout — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Only fill in keys for sources you've ENABLED in input/settings.yaml.
# Leave unused keys blank — they will be skipped automatically.
# =============================================================================

# ── LLM (Required) ──────────────────────────────────────────────────────────
# Any OpenAI-compatible endpoint: DashScope, OpenAI, Azure, Ollama, etc.
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_dashscope_api_key_here
LLM_MODEL=qwen3.6-plus

# ── OpenAlex (Free, no key needed) ──────────────────────────────────────────
# Providing your email gets you faster rate limits ("polite pool").
OPENALEX_EMAIL=your_email@example.com

# ── Semantic Scholar (Free, key optional) ────────────────────────────────────
# Without key: shared rate limit. With key: 1 req/sec guaranteed.
# Request key: https://www.semanticscholar.org/product/api#api-key
S2_API_KEY=

# ── Elsevier / ScienceDirect (Institutional) ────────────────────────────────
# API key: https://dev.elsevier.com/ (sign up with university email)
# Inst token: email datasupport@elsevier.com (needed for off-campus access)
ELSEVIER_API_KEY=
ELSEVIER_INST_TOKEN=

# ── arXiv (Free, no key needed) ─────────────────────────────────────────────
# No credentials required. Nothing to fill in here.

# ── PubMed / NCBI (Free, key optional) ──────────────────────────────────────
# Without key: 3 req/sec. With key: 10 req/sec.
# Get key: https://www.ncbi.nlm.nih.gov/account/settings/
PUBMED_API_KEY=

# ── CORE (Free key required) ────────────────────────────────────────────────
# Register for free API key: https://core.ac.uk/services/api
CORE_API_KEY=
